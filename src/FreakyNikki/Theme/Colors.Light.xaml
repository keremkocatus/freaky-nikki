<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base surfaces -->
    <Color x:Key="Color.Background">#FFF5F6F8</Color>
    <Color x:Key="Color.Surface">#FFFFFFFF</Color>
    <Color x:Key="Color.SurfaceHover">#FFEEF0F3</Color>
    <Color x:Key="Color.Border">#FFE2E5EA</Color>
    <Color x:Key="Color.TextPrimary">#FF1A1C1E</Color>
    <Color x:Key="Color.TextSecondary">#FF6B7178</Color>

    <!-- Accent (default; overridden with the Windows accent at runtime) -->
    <Color x:Key="Color.Accent">#FF6366F1</Color>
    <Color x:Key="Color.AccentHover">#FF4F52D6</Color>
    <Color x:Key="Color.OnAccent">#FFFFFFFF</Color>

    <!-- Status dots -->
    <Color x:Key="Color.StatusIdle">#FF9AA1AA</Color>
    <Color x:Key="Color.StatusPlaying">#FF16A34A</Color>
    <Color x:Key="Color.StatusReconnecting">#FFD97706</Color>
    <Color x:Key="Color.StatusError">#FFDC2626</Color>

    <SolidColorBrush x:Key="Brush.Background" Color="{DynamicResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{DynamicResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceHover" Color="{DynamicResource Color.SurfaceHover}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{DynamicResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{DynamicResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{DynamicResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{DynamicResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{DynamicResource Color.AccentHover}" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="{DynamicResource Color.OnAccent}" />
    <SolidColorBrush x:Key="Brush.StatusIdle" Color="{DynamicResource Color.StatusIdle}" />
    <SolidColorBrush x:Key="Brush.StatusPlaying" Color="{DynamicResource Color.StatusPlaying}" />
    <SolidColorBrush x:Key="Brush.StatusReconnecting" Color="{DynamicResource Color.StatusReconnecting}" />
    <SolidColorBrush x:Key="Brush.StatusError" Color="{DynamicResource Color.StatusError}" />

</ResourceDictionary>
